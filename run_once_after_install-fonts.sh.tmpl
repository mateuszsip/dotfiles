#!/bin/bash
set -eufo pipefail

NERD_FONTS_VERSION="3.4.0"
JETBRAINS_MONO_URL="https://github.com/ryanoasis/nerd-fonts/releases/download/v${NERD_FONTS_VERSION}/JetBrainsMono.zip"

{{- if eq .chezmoi.os "darwin" }}
FONT_DIR="$HOME/Library/Fonts"
{{- else }}
FONT_DIR="$HOME/.local/share/fonts"
mkdir -p "$FONT_DIR"
{{- end }}

tmp=$(mktemp -d)
trap 'rm -rf "$tmp"' EXIT

echo "Installing JetBrains Mono Nerd Font v${NERD_FONTS_VERSION}..."
curl -fsSL "$JETBRAINS_MONO_URL" -o "$tmp/JetBrainsMono.zip"
unzip -q "$tmp/JetBrainsMono.zip" -d "$tmp/extracted"
find "$tmp/extracted" -name "*.ttf" -exec cp {} "$FONT_DIR/" \;

{{- if eq .chezmoi.os "linux" }}
fc-cache -f "$FONT_DIR"
{{- end }}

echo "JetBrains Mono Nerd Font installed."
