{{- if eq .chezmoi.os "linux" -}}
#!/bin/bash
# pacman: {{ include "packages_arch.txt" | sha256sum }}
# aur:    {{ include "packages_arch_aur.txt" | sha256sum }}
set -eufo pipefail

sudo pacman -S --needed --noconfirm \
{{ include "packages_arch.txt" | trim | splitList "\n" | join " \\\n  " }}

if ! command -v paru &>/dev/null && ! command -v yay &>/dev/null; then
  sudo pacman -S --needed --noconfirm base-devel git
  tmp=$(mktemp -d)
  git clone https://aur.archlinux.org/paru.git "$tmp/paru"
  (cd "$tmp/paru" && makepkg -si --noconfirm)
  rm -rf "$tmp"
fi

aur_helper=$(command -v paru || command -v yay)

$aur_helper -S --needed --noconfirm \
{{ include "packages_arch_aur.txt" | trim | splitList "\n" | join " \\\n  " }}
{{- else if eq .chezmoi.os "darwin" -}}
#!/bin/bash
# brew: {{ include "packages_macos.txt" | sha256sum }}
# taps: {{ include "packages_macos_taps.txt" | sha256sum }}
set -eufo pipefail

if ! command -v brew &>/dev/null; then
  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi

brew install \
{{ include "packages_macos.txt" | trim | splitList "\n" | join " \\\n  " }}

while IFS= read -r formula; do
  [ -z "$formula" ] && continue
  brew tap "${formula%/*}"
  brew install "$formula"
done <<'TAPS'
{{ include "packages_macos_taps.txt" | trim }}
TAPS

tapped_short=$(cat <<'TAPS' | sed 's|.*/||'
{{ include "packages_macos_taps.txt" | trim }}
TAPS
)

expected=$(printf '%s\n%s' \
  "$(sort <<'EOF'
{{ include "packages_macos.txt" | trim }}
EOF
)" \
  "$tapped_short" | sort)

extras=$(comm -23 <(brew list --installed-on-request | sort) <(echo "$expected"))
if [ -n "$extras" ]; then
  echo "Uninstalling on-request packages not in packages_macos.txt:"
  echo "$extras" | sed 's/^/  /'
  while IFS= read -r pkg; do
    [ -z "$pkg" ] && continue
    brew uninstall "$pkg" || echo "  skipped $pkg (still required by another formula)"
  done <<< "$extras"
fi
{{- end }}
