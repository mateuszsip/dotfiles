{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "home-assistant": {
      "enabled": true,
      "type": "remote",
      "url": "http://mcp.smart.local.sipex.cloud/mcp"
    },
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer {env:GITHUB_PERSONAL_ACCESS_TOKEN}"
      }
    },
  },
  "plugin": [
    "@mohak34/opencode-notifier@latest",
  ]
}

