set theme base16-grayscale-light

" Unbind to clear the slate
unbind j
unbind k
unbind l
unbind ;
unbind H
unbind J
unbind K
unbind L

unbind <C-f>

" Map jkl; to Left, Down, Up, Right
bind j scrollpx -50 0
bind k scrollline 10
bind l scrollline -10
bind ; scrollpx 50 0

" Tab switching
bind L tabprev
bind K tabnext

" History navigation
bind H back
bind J forward

" Important: Move the command prefix from ; to h
bind h fillcmdline

" Hint operations (, replaces ; prefix which is now scroll right)
bind f hint
bind ,f hint
bind ,t hint -t
bind ,b hint -b
bind Y hint -y
bind ,y hint -y
bind ,p hint -p
bind ,a hint -#

" Tab management
bind d tabclose
bind u undo

" Clipboard
bind yy clipboard yank
bind p open clipboard

" Focus input
bind gi focusinput

" Visual mode navigation (jkl; instead of hjkl)
unbind --mode=visual h
unbind --mode=visual j
unbind --mode=visual k
unbind --mode=visual l
unbind --mode=visual ;

bind --mode=visual j js const sel = document.getSelection(); tri.visual.extendByCharacter(sel, "backward");
bind --mode=visual k js document.getSelection().modify("extend","forward","line")
bind --mode=visual l js document.getSelection().modify("extend","backward","line")
bind --mode=visual ; js const sel = document.getSelection(); tri.visual.extendByCharacter(sel, "forward");

