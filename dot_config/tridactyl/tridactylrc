" Unbind to clear the slate
unbind j
unbind k
unbind l
unbind ;
unbind H
unbind J
unbind K
unbind L

unbind <C-f>

" Map jkl; to Left, Down, Up, Right
bind j scrollpx -50 0
bind k scrollline 10
bind l scrollline -10
bind ; scrollpx 50 0

" Tab switching
bind K tabprev
bind L tabnext

" History navigation
bind H back
bind J forward

" Important: Move the command prefix from ; to h
bind h fillcmdline

" Hint operations (, replaces ; prefix which is now scroll right)
bind f hint
bind ,f hint
bind ,t hint -t
bind ,b hint -b
bind Y hint -y

" Tab management
bind d tabclose
bind u undo

" Clipboard
bind yy clipboard yank
bind p open clipboard

" Focus input
bind gi focusinput
