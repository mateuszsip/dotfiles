set theme base16-grayscale-light

" Unbind to clear the slate
unbind j
unbind k
unbind l
unbind ;
unbind H
unbind J
unbind K
unbind L

unbind <C-f>

" Map jkl; to Left, Down, Up, Right
bind j scrollpx -50 0
bind k scrollline 10
bind l scrollline -10
bind ; scrollpx 50 0

" Tab switching
bind L tabprev
bind K tabnext

" History navigation
bind H back
bind J forward

" Important: Move the command prefix from ; to h
bind h fillcmdline

" Hint operations (, replaces ; prefix which is now scroll right)
bind f hint
bind ,f hint
bind ,t hint -t
bind ,b hint -b
bind Y hint -y
bind ,y hint -y
bind ,p hint -p
bind ,a hint -#

" Tab management
bind d jsb browser.tabs.query({active: true, currentWindow: true}).then(async tabs => { let tab = tabs[0]; if (tab.pinned) { let all = await browser.tabs.query({currentWindow: true}); if (all.length > 1) { let idx = all.findIndex(t => t.id === tab.id); await browser.tabs.update(all[(idx + 1) % all.length].id, {active: true}); } await browser.tabs.discard(tab.id); } else { await browser.tabs.remove(tab.id); } })
bind gD jsb browser.tabs.query({}).then(ts => browser.tabs.discard(ts.map(t => t.id)))
bind u undo

" Clipboard
bind yy clipboard yank
bind p open clipboard

" Focus input
bind gi focusinput

" Visual mode navigation (jkl; instead of hjkl)
unbind --mode=visual h
unbind --mode=visual j
unbind --mode=visual k
unbind --mode=visual l
unbind --mode=visual ;

bind --mode=visual j js document.getSelection().modify("extend","backward","character")
bind --mode=visual k js document.getSelection().modify("extend","forward","line")
bind --mode=visual l js document.getSelection().modify("extend","backward","line")
bind --mode=visual ; js document.getSelection().modify("extend","forward","character")

