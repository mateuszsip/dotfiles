# See https://git-scm.com/docs/git-config

[alias]
	co = checkout
	br = branch
	ci = commit
	st = status
[init]
	defaultBranch = main
[pull]
	rebase = true 			 # Rebase (instead of merge) on pull
[push]
	autoSetupRemote = true   # Automatically set upstream branch on push
[diff]
	algorithm = histogram    # Clearer diffs on moved/edited lines
	colorMoved = plain       # Highlight moved blocks in diffs
	mnemonicPrefix = true    # More intuitive refs in diff output
	tool = nvimdiff
[commit]
	verbose = true           # Include diff comment in commit message template
	gpgsign = true
[column]
	ui = auto 			     # Output in columns when possible
[branch]
	sort = -committerdate    # Sort branches by most recent commit first
[tag]
	sort = -version:refname  # Sort version numbers as you would expect
[rerere]
	enabled = true           # Record and reuse conflict resolutions
	autoupdate = true        # Apply stored conflict resolutions automatically
[user]
	name = Mateusz Sip
	email = mateusz.sip@gmail.com
	signingkey = ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAII6L65dhR4NT4S8lIrG+TIL5qp1F0du0SD3ulOgiv9rX
[gpg]
  format = ssh
[core]
  sshCommand = /usr/bin/ssh
  pager = delta
[interactive]
  diffFilter = delta --color-only
[delta]
  navigate = true  # use n and N to move between diff sections
  light = true      # or light = true, or omit for auto-detection
  side-by-side = true
[merge]
  conflictStyle = zdiff3
[difftool]
	prompt = false
[difftool "delta"]
	cmd = delta --pager=\"less -R\" --side-by-side --light \"$LOCAL\" \"$REMOTE\"
[difftool "nvimdiff"]
	cmd = "f() { l=\"$1\"; r=\"$2\"; tl=\"\"; tr=\"\"; if [ \"$l\" = \"/dev/null\" ]; then tl=$(mktemp); l=\"$tl\"; fi; if [ \"$r\" = \"/dev/null\" ]; then tr=$(mktemp); r=\"$tr\"; fi; nvim -c \"packadd nvim.difftool\" -c \"lua local d = require('difftool'); local old = d.open; d.open = function(l,r,o) local function touch(p) if p and p ~= '' and vim.fn.isdirectory(p) == 0 and vim.fn.filereadable(p) == 0 then local f = io.open(p, 'w') if f then f:close() end end end; touch(l); touch(r); old(l,r,o) end\" -c \"DiffTool $l $r\"; [ -n \"$tl\" ] && rm -f \"$tl\"; [ -n \"$tr\" ] && rm -f \"$tr\"; }; f \"$LOCAL\" \"$REMOTE\""
[merge]
  tool = nvimdiff
[mergetool]
  prompt = false
  keepBackup = false
[mergetool "nvimdiff"]
  layout = "LOCAL,BASE,REMOTE / MERGED"
