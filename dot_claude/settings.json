{
  "permissions": {
    "allow": [
      "Bash(git add:*)",
      "Read(/home/sip/.config/**)",
      "Edit(/home/sip/.config/**)",
      "Read(/home/sip/.local/share/chezmoi/**)",
      "Edit(/home/sip/.local/share/chezmoi/**)"
    ],
    "deny": [
      "Read(*.env)",
      "Bash(rm:*)",
      "Bash(curl:*)"
    ],
    "ask": [
      "Bash(gh pr create:*)",
      "Bash(git commit:*)"
    ],
    "defaultMode": "auto"
  },
  "model": "sonnet",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": []
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "atuin hook claude-code"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "atuin hook claude-code"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/home/sip/.claude/hooks/rtk-rewrite.sh"
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": []
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "atuin hook claude-code"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash /home/sip/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "github@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true
  },
  "preferredNotifChannel": "ghostty",
  "theme": "light",
  "skipAutoPermissionPrompt": true
}
