{
  "enabledPlugins": {
    "github@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true
  },
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [],
        "matcher": "*"
      },
      {
        "hooks": [
          {
            "command": "atuin hook claude-code",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "command": "atuin hook claude-code",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "rtk hook claude"
          }
        ]
      },
      {
        "hooks": [
          {
            "command": "atuin hook claude-code",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ],
    "Stop": [
      {
        "hooks": [
{{ if eq .chezmoi.os "linux" -}}
          {
            "command": "bash ~/.config/waybar/claude-notify.sh",
            "type": "command"
          }
{{ end -}}
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(git add:*)",
      "Read({{ .chezmoi.homeDir }}/.config/**)",
      "Edit({{ .chezmoi.homeDir }}/.config/**)",
      "Read({{ .chezmoi.homeDir }}/.local/share/chezmoi/**)",
      "Edit({{ .chezmoi.homeDir }}/.local/share/chezmoi/**)"
    ],
    "ask": [
      "Bash(gh pr create:*)",
      "Bash(git commit:*)"
    ],
    "defaultMode": "auto",
    "deny": [
      "Read(*.env)",
      "Bash(rm:*)",
      "Bash(curl:*)"
    ]
  },
  "statusLine": {
    "command": "bash {{ .chezmoi.homeDir }}/.claude/statusline-command.sh",
    "type": "command"
  },
  "theme": "light",
  "model": "sonnet",
  "skipAutoPermissionPrompt": true
}
